<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>RYFT Esports</title>
    <link rel="stylesheet" href="/css/style.css">
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&display=swap" rel="stylesheet">
</head>
<body>

<nav>
    <div class="logo">RYFT</div>
    <ul>
        <li>Home</li>
        <li>Tournaments</li>
        <li>Leaderboard</li>
        <li>Contact</li>
    </ul>
</nav>

<section class="hero">
    <h1>PLAY. RISE. <span>DOMINATE.</span></h1>
    <p>India’s next-generation esports platform for competitive warriors.</p>

    <div class="buttons">
        <a href="/login" class="btn primary">Join Now</a>
        <a href="/tournaments" class="btn secondary">Browse Tournaments</a>
    </div>
</section>

<section class="stats">
    <div class="card">
        <h2>5,000+</h2>
        <p>Players</p>
    </div>
    <div class="card">
        <h2>₹50,000+</h2>
        <p>Prize Pool</p>
    </div>
    <div class="card">
        <h2>120+</h2>
        <p>Matches Hosted</p>
    </div>
</section>

</body>
</html>